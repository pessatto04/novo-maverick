+/* ============================================
+   BUSCA NO MENU LATERAL (NOVO - pessatto04)
+   ============================================ */
+
+.mv-search-wrapper {
+  position: relative;
+  display: flex;
+  align-items: center;
+  margin-bottom: 8px;
+}
+
+.mv-search-icon {
+  position: absolute;
+  left: 10px;
+  color: var(--mv-text-muted);
+  font-size: 0.8rem;
+  pointer-events: none;
+}
+
+.mv-search-input {
+  width: 100%;
+  padding: 7px 60px 7px 30px;
+  border-radius: 8px;
+  border: 1px solid var(--mv-sidebar-border);
+  background-color: var(--mv-nav-item-hover);
+  color: var(--mv-text);
+  font-size: 0.82rem;
+  outline: none;
+  transition: var(--mv-transition);
+}
+
+.mv-search-input:focus {
+  border-color: var(--mv-accent);
+  background-color: var(--mv-card-bg);
+  box-shadow: 0 0 0 2px color-mix(in srgb, var(--mv-accent) 20%, transparent);
+}
+
+.mv-search-input::placeholder {
+  color: var(--mv-text-muted);
+}
+
+.mv-search-clear {
+  position: absolute;
+  right: 32px;
+  background: none;
+  border: none;
+  color: var(--mv-text-muted);
+  cursor: pointer;
+  padding: 0;
+  font-size: 1rem;
+  line-height: 1;
+  display: flex;
+  align-items: center;
+}
+
+.mv-search-clear:hover {
+  color: var(--mv-text);
+}
+
+.mv-search-hint {
+  position: absolute;
+  right: 8px;
+  font-size: 0.65rem;
+  color: var(--mv-text-muted);
+  background: var(--mv-sidebar-border);
+  padding: 1px 4px;
+  border-radius: 4px;
+  pointer-events: none;
+  white-space: nowrap;
+}
+
+.mv-search-empty {
+  font-size: 0.82rem;
+  color: var(--mv-text-muted);
+  text-align: center;
+  padding: 12px 0;
+  margin: 0;
+}
+
